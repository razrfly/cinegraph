<!DOCTYPE html>
<html lang="en" class="bg-mist-100">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <title>Pricing — Oatmeal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/oatmeal.css"} />
  </head>
  <body class="bg-mist-100 text-mist-950 antialiased font-sans">
    <header class="sticky top-0 z-10 bg-mist-100">
      <nav class="mx-auto flex h-[5.25rem] max-w-7xl items-center gap-4 px-6 lg:px-10">
        <div class="flex flex-1 gap-8 max-lg:hidden">
          <a href={~p"/oatmeal-demo/pricing"} class="text-sm/7 font-medium text-mist-950">
            Pricing
          </a>
          <a href={~p"/oatmeal-demo/about"} class="text-sm/7 font-medium text-mist-950">About</a>
          <a href="#" class="text-sm/7 font-medium text-mist-950">Docs</a>
        </div>
        <div class="flex items-center">
          <a href={~p"/oatmeal-demo"} class="font-display text-2xl text-mist-950 italic">
            Oatmeal
          </a>
        </div>
        <div class="flex flex-1 items-center justify-end gap-4">
          <a
            href="#"
            class="inline-flex shrink-0 items-center justify-center gap-2 rounded-full px-3 py-1 text-sm/7 font-medium text-mist-950 hover:bg-mist-950/10 max-sm:hidden"
          >
            Log in
          </a>
          <a
            href="#"
            class="inline-flex shrink-0 items-center justify-center gap-1 rounded-full bg-mist-950 px-3 py-1 text-sm/7 font-medium text-mist-100 hover:bg-mist-800"
          >
            Get started
          </a>
        </div>
      </nav>
    </header>

    <main class="isolate overflow-clip">
      <%!-- PRICING HERO --%>
      <section class="py-16">
        <div class="mx-auto w-full max-w-2xl px-6 md:max-w-3xl lg:max-w-7xl lg:px-10 flex flex-col items-center gap-10 text-center">
          <h1 class="font-display text-5xl/[3rem] tracking-tight text-balance text-mist-950 italic sm:text-[5rem]/[5rem]">
            Pricing that earns its keep.
          </h1>
          <p class="max-w-2xl text-lg/8 text-mist-700">
            Start free. Pay only when your team grows past the basics. We'd rather you stay on
            Starter than upgrade for features you don't use.
          </p>
        </div>
      </section>

      <%!-- PRICING TIERS --%>
      <section class="py-16">
        <div class="mx-auto w-full max-w-2xl px-6 md:max-w-3xl lg:max-w-7xl lg:px-10">
          <div class="grid grid-cols-1 gap-2 lg:grid-cols-3">
            <div
              :for={
                p <- [
                  %{
                    name: "Starter",
                    price: "$12",
                    per: "/mo",
                    desc: "Small teams getting started with shared inboxes",
                    cta: "soft",
                    badge: nil,
                    features: [
                      "Shared inbox for up to 2 mailboxes",
                      "Tagging & assignment",
                      "Private notes",
                      "Automatic replies",
                      "Email support"
                    ]
                  },
                  %{
                    name: "Growth",
                    price: "$49",
                    per: "/mo",
                    desc: "Growing teams needing collaboration and insights",
                    cta: "primary",
                    badge: "Most popular",
                    features: [
                      "Everything in Starter",
                      "Inbox Agent",
                      "Unlimited mailboxes",
                      "Collision detection",
                      "Snippets and templates",
                      "Reporting dashboard",
                      "Slack integration"
                    ]
                  },
                  %{
                    name: "Pro",
                    price: "$299",
                    per: "/mo",
                    desc: "Support-focused organizations and larger teams",
                    cta: "soft",
                    badge: nil,
                    features: [
                      "Everything in Growth",
                      "Custom roles & permissions",
                      "Automation engine",
                      "API access",
                      "SLA tracking",
                      "SSO support",
                      "SOC 2 compliance"
                    ]
                  }
                ]
              }
              class="flex flex-col justify-between gap-6 rounded-xl bg-mist-950/[0.025] p-6"
            >
              <div class="self-stretch">
                <div class="flex items-center justify-between">
                  <span
                    :if={p.badge}
                    class="order-last inline-flex rounded-full bg-mist-950/10 px-2 text-xs/6 font-medium text-mist-950"
                  >
                    {p.badge}
                  </span>
                  <h3 class="text-2xl/8 tracking-tight text-mist-950">{p.name}</h3>
                </div>
                <p class="mt-1 inline-flex gap-1 text-base/7">
                  <span class="text-mist-950">{p.price}</span>
                  <span class="text-mist-500">{p.per}</span>
                </p>
                <div class="mt-4 flex flex-col gap-4 text-sm/6 text-mist-700">
                  <p>{p.desc}</p>
                </div>
                <ul class="mt-4 space-y-2 text-sm/6 text-mist-700">
                  <li :for={f <- p.features} class="flex gap-4">
                    <svg
                      width="13"
                      height="13"
                      viewBox="0 0 13 13"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1"
                      class="h-[1lh] shrink-0 stroke-mist-950"
                    >
                      <path
                        d="M1.5 6.5L5.5 11.5L11.5 1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    <p>{f}</p>
                  </li>
                </ul>
              </div>
              <a
                href="#"
                class={[
                  "inline-flex shrink-0 items-center justify-center gap-1 rounded-full px-4 py-2 text-sm/7 font-medium",
                  if(p.cta == "primary",
                    do: "bg-mist-950 text-mist-100 hover:bg-mist-800",
                    else: "bg-mist-950/10 text-mist-950 hover:bg-mist-950/15"
                  )
                ]}
              >
                Start free trial
              </a>
            </div>
          </div>
        </div>
      </section>

      <%!-- PLAN COMPARISON --%>
      <section class="py-16">
        <div class="mx-auto w-full max-w-2xl px-6 md:max-w-3xl lg:max-w-7xl lg:px-10">
          <div class="flex max-w-2xl flex-col gap-6 mb-10">
            <div class="text-sm/7 font-semibold text-mist-700">Compare plans</div>
            <h2 class="font-display text-3xl/9 tracking-tight text-pretty text-mist-950 italic sm:text-[3rem]/[3rem]">
              All the boring details, in one table.
            </h2>
          </div>
          <div class="overflow-x-auto rounded-lg border border-mist-950/10 bg-mist-100">
            <table class="w-full text-left text-sm/7">
              <thead class="text-mist-700">
                <tr class="border-b border-mist-950/10">
                  <th class="px-6 py-4 font-semibold">Feature</th>
                  <th class="px-6 py-4 font-semibold">Starter</th>
                  <th class="px-6 py-4 font-semibold text-mist-950">Growth</th>
                  <th class="px-6 py-4 font-semibold">Pro</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-mist-950/10 text-mist-950">
                <tr :for={
                  row <- [
                    {"Mailboxes", "Up to 2", "Unlimited", "Unlimited"},
                    {"Team members", "5", "25", "Unlimited"},
                    {"Inbox Agent (AI)", "—", "✓", "✓"},
                    {"Snippets & templates", "—", "✓", "✓"},
                    {"Collision detection", "—", "✓", "✓"},
                    {"Reporting dashboard", "—", "Standard", "Advanced"},
                    {"API access", "—", "—", "✓"},
                    {"SLA tracking", "—", "—", "✓"},
                    {"SSO / SAML", "—", "—", "✓"},
                    {"SOC 2 documentation", "—", "—", "✓"},
                    {"Support", "Email", "Chat + Email", "Dedicated CSM"}
                  ]
                }>
                  <td class="px-6 py-3 font-medium">{elem(row, 0)}</td>
                  <td class="px-6 py-3 text-mist-700">{elem(row, 1)}</td>
                  <td class="px-6 py-3">{elem(row, 2)}</td>
                  <td class="px-6 py-3 text-mist-700">{elem(row, 3)}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <%!-- FAQ --%>
      <section class="py-16">
        <div class="mx-auto w-full max-w-2xl px-6 md:max-w-3xl lg:max-w-7xl lg:px-10 grid grid-cols-1 gap-x-2 gap-y-8 lg:grid-cols-2">
          <div class="flex flex-col gap-6">
            <h2 class="font-display text-3xl/9 tracking-tight text-pretty text-mist-950 italic sm:text-[3rem]/[3rem]">
              Pricing questions, briefly answered.
            </h2>
          </div>
          <dl class="divide-y divide-mist-950/10 border-y border-mist-950/10">
            <div
              :for={
                f <- [
                  %{
                    q: "Is the trial really free?",
                    a:
                      "Yes. 14 days, all features, no credit card required. We'll email you twice during the trial; we won't keep emailing after."
                  },
                  %{
                    q: "Do you charge per seat?",
                    a:
                      "Growth and Pro are flat-rate up to a generous cap (25 seats on Growth). Past that, $9/seat. Starter is fixed-team."
                  },
                  %{
                    q: "Can I switch plans?",
                    a: "Yes, any time. Downgrades take effect at the next billing cycle."
                  },
                  %{
                    q: "Discounts for nonprofits?",
                    a:
                      "30% off Growth and Pro for registered nonprofits. Email support@oatmeal with documentation."
                  }
                ]
              }
              class="py-4"
            >
              <dt class="text-base/7 text-mist-950 font-medium">{f.q}</dt>
              <dd class="mt-1 text-sm/7 text-mist-700">{f.a}</dd>
            </div>
          </dl>
        </div>
      </section>
    </main>

    <footer class="pt-16">
      <div class="bg-mist-950/[0.025] py-10 text-mist-700">
        <div class="mx-auto w-full max-w-7xl px-6 lg:px-10 text-center text-sm/7">
          &copy; {Date.utc_today().year} Oatmeal, Inc. — demo page on Cinegraph
        </div>
      </div>
    </footer>
  </body>
</html>
