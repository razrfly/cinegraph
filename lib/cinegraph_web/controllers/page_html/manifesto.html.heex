    <footer class="border-t border-mist-950/10 bg-mist-50">
      <div class="mx-auto flex w-full max-w-2xl flex-col gap-8 px-6 py-12 md:max-w-3xl lg:max-w-7xl lg:flex-row lg:items-center lg:justify-between lg:px-10">
        <div class="inline-flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="4" class="fill-mist-950" /><path
              d="M7 12 L11 8 L15 14 L17 11"
              fill="none"
              stroke="#fff"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
            /><circle cx="7" cy="12" r="1.4" fill="#fff" /><circle
              cx="11"
              cy="8"
              r="1.4"
              fill="#fff"
            /><circle cx="15" cy="14" r="1.4" fill="#fff" /><circle
              cx="17"
              cy="11"
              r="1.4"
              fill="#fff"
            />
          </svg>
          <span class="text-[15px] font-semibold text-mist-950">Cinegraph</span>
        </div>
        <p class="font-display text-[20px] italic text-mist-700">
          Film discovery is broken. Your agenda is not theirs.
        </p>
        <div class="text-[12.5px] text-mist-500">
          Independent · evidence-based · nothing to sell you
        </div>
      </div>
    </footer>

    <script>
      // Cinegraph manifesto — interactivity (self-contained; no LiveSocket on this page)
      (function () {
        "use strict";

        /* Scroll reveal */
        var reveal = document.querySelectorAll(".reveal");
        if ("IntersectionObserver" in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); }
            });
          }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });
          reveal.forEach(function (el) { io.observe(el); });
        } else {
          reveal.forEach(function (el) { el.classList.add("in"); });
        }

        /* Provenance bars fill when in view */
        var prov = document.querySelector(".prov");
        if (prov) {
          if ("IntersectionObserver" in window) {
            var pio = new IntersectionObserver(function (entries) {
              entries.forEach(function (e) {
                if (e.isIntersecting) { prov.classList.add("in"); pio.unobserve(e.target); }
              });
            }, { threshold: 0.3 });
            pio.observe(prov);
          } else {
            prov.classList.add("in");
          }
        }
      })();
    </script>
  </body>
</html>
