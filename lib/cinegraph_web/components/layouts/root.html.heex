<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Cinegraph" suffix=" · Cinegraph">
      {assigns[:page_title]}
    </.live_title>
    <CinegraphWeb.SEO.meta_tags assigns={assigns} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <.clerk_head />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="bg-white">
    <header class="px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="flex items-center justify-between border-b border-zinc-100 py-3">
          <div class="flex items-center gap-6">
            <a href="/" class="text-lg font-bold text-zinc-900">
              Cinegraph
            </a>
            <nav class="flex items-center gap-4 text-sm font-medium">
              <.link navigate={~p"/movies"} class="text-zinc-700 hover:text-zinc-900">
                Movies
              </.link>
              <.link navigate={~p"/lists"} class="text-zinc-700 hover:text-zinc-900">
                Lists
              </.link>
              <.link navigate={~p"/awards"} class="text-zinc-700 hover:text-zinc-900">
                Awards
              </.link>
              <.link navigate={~p"/people"} class="text-zinc-700 hover:text-zinc-900">
                People
              </.link>
              <.link navigate={~p"/movies/discover"} class="text-zinc-700 hover:text-zinc-900">
                Discovery
              </.link>
              <.link navigate={~p"/explore/disparity"} class="text-zinc-700 hover:text-zinc-900">
                Disparity
              </.link>
            </nav>
          </div>
          <!-- Clerk auth UI (#838) — hydrated client-side by app.js. -->
          <div data-clerk-auth-ui class="flex items-center gap-3 text-sm font-medium">
            <div data-clerk-loading class="h-5 w-24 rounded bg-zinc-100 animate-pulse"></div>
            <div data-clerk-signed-out class="hidden items-center gap-4">
              <a href="/auth/login" class="text-zinc-700 hover:text-zinc-900">Log in</a>
              <a
                href="/auth/register"
                class="rounded-md bg-zinc-900 px-3 py-1.5 text-white hover:bg-zinc-700"
              >
                Sign up
              </a>
            </div>
            <div data-clerk-signed-in class="hidden items-center gap-4">
              <a href="/auth/profile" class="text-zinc-700 hover:text-zinc-900">Account</a>
              <a href="/auth/logout" class="text-zinc-700 hover:text-zinc-900">Log out</a>
            </div>
          </div>
        </div>
      </div>
    </header>
    {@inner_content}
  </body>
</html>
